{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "InputBucket": "mc-demo-input-123456789012-us-east-1",
    "OutputBucket": "mc-demo-output-123456789012-us-east-1",
    "UploadPrefix": "uploads",
    "OutputPrefix": "outputs",
    "ManifestPrefix": "system/jobs",
    "PresignedUrlExpirationMinutes": 15
  },
  "MediaConvert": {
    "Endpoint": "https://mediaconvert.us-east-1.amazonaws.com",
    "RoleArn": "arn:aws:iam::123456789012:role/MediaConvertDemoRole",
    "QueueArn": "",
    "WorkflowName": "MediaConvert.Transcode.Demo",
    "Template": {
      "Name": "mc-demo-hls-ladder",
      "OutputGroups": [
        {
          "Name": "hls-360p",
          "Prefix": "360p/",
          "GroupType": "HLS"
        },
        {
          "Name": "hls-480p",
          "Prefix": "480p/",
          "GroupType": "HLS"
        },
        {
          "Name": "hls-720p",
          "Prefix": "720p/",
          "GroupType": "HLS"
        }
      ]
    }
  },
  "AllowedHosts": "*"
}
