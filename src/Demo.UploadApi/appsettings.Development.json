{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "InputBucket": "mc-demo-input-local",
    "OutputBucket": "mc-demo-output-local"
  },
  "MediaConvert": {
    "Endpoint": "https://replace-me.mediaconvert.us-east-1.amazonaws.com",
    "RoleArn": "arn:aws:iam::123456789012:role/MediaConvertDemoRole",
    "Template": {
      "Name": "mc-demo-hls-ladder",
      "OutputGroups": [
        {
          "Name": "hls-360p",
          "Prefix": "360p/",
          "GroupType": "HLS"
        },
        {
          "Name": "hls-480p",
          "Prefix": "480p/",
          "GroupType": "HLS"
        },
        {
          "Name": "hls-720p",
          "Prefix": "720p/",
          "GroupType": "HLS"
        }
      ]
    }
  }
}
